{
	"info": {
		"_postman_id": "flowdo-api-collection",
		"name": "FlowDo API",
		"description": "FlowDo Backend API Collection — Laravel 13 + Sanctum (Cookie-based SPA Authentication)\n\n## Cara Pakai\n1. Jalankan `CSRF Cookie` terlebih dahulu untuk mendapatkan XSRF-TOKEN.\n2. Jalankan `Register` atau `Login` untuk autentikasi.\n3. Postman otomatis menyimpan cookie session, sehingga request selanjutnya sudah terotentikasi.\n4. Variable `taskId` dan `tagId` otomatis ter-set dari response `Create Task` dan `Create Tag`.\n\n## Base URL\nDefault: `http://127.0.0.1:8000`",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8000",
			"type": "string"
		},
		{
			"key": "taskId",
			"value": "",
			"type": "string"
		},
		{
			"key": "tagId",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "🔐 Authentication",
			"description": "Endpoint autentikasi: CSRF cookie, register, login, logout, dan cek user session.",
			"item": [
				{
					"name": "CSRF Cookie",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Referer",
								"value": "{{baseUrl}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/sanctum/csrf-cookie",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"sanctum",
								"csrf-cookie"
							]
						},
						"description": "Ambil XSRF-TOKEN cookie dari Sanctum. Harus dipanggil SEBELUM register/login agar Postman menyimpan cookie CSRF."
					},
					"response": []
				},
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    pm.test('Register berhasil', function () {",
									"        var json = pm.response.json();",
									"        pm.expect(json).to.have.property('id');",
									"        pm.expect(json).to.have.property('name');",
									"        pm.expect(json).to.have.property('email');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
